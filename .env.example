# GitHub Contents API에 커밋하기 위한 설정
# 아래 값을 실제 값으로 채운 뒤, Vercel 프로젝트의 Environment Variables에도 동일하게 등록하세요.
# 로컬에서 `vercel dev`로 테스트할 때는 이 파일을 복사해 .env.local로 저장하세요.

# Fine-grained personal access token (해당 저장소, Contents: Read and write 권한만)
GITHUB_TOKEN=

# 데이터를 저장할 공개 저장소 정보
GITHUB_OWNER=your-github-username
GITHUB_REPO=meeting-availability-data
GITHUB_BRANCH=main
